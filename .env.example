# ==================== Database ====================
POSTGRES_DB=medigt
POSTGRES_USER=medigt
POSTGRES_PASSWORD=medigt
POSTGRES_PORT=5450
DATABASE_URL=postgres://medigt:medigt@localhost:5450/medigt?sslmode=disable
# Optional pgxpool tuning. Defaults are 25 / 5 per pod.
# DATABASE_MAX_CONNS=25
# DATABASE_MIN_CONNS=5

# ==================== Server ====================
# APP_ENV gates dev-only auth shortcuts (master code 888888).
# Leave unset for local dev. Set to "production" for prod.
APP_ENV=
PORT=8088
JWT_SECRET=change-me-in-production
MEDIGT_SERVER_URL=ws://localhost:8088/ws
MEDIGT_APP_URL=http://localhost:3008

# ==================== Email (Resend) ====================
# For local/dev, leave RESEND_API_KEY empty — codes print to stdout.
# Master code 888888 works when APP_ENV != "production".
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@medigt.local

# ==================== Google OAuth (optional) ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3008/auth/callback

# ==================== Redis (realtime relay, optional) ====================
# Required only for multi-node deployments. Local dev can omit.
REDIS_URL=

# ==================== S3 / Object Storage ====================
# Used for patient documents, radiology images, exported reports.
S3_BUCKET=
S3_REGION=eu-central-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Local fallback (when S3_BUCKET is not set)
LOCAL_UPLOAD_DIR=./data/uploads
LOCAL_UPLOAD_BASE_URL=http://localhost:8088

# ==================== Security ====================
# Comma-separated allowed origins for CORS and WebSocket.
# Defaults to localhost dev origins when unset.
ALLOWED_ORIGINS=
COOKIE_DOMAIN=

# ==================== Frontend ====================
FRONTEND_PORT=3008
FRONTEND_ORIGIN=http://localhost:3008
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# ==================== Signup Control ====================
ALLOW_SIGNUP=true
ALLOWED_EMAIL_DOMAINS=
ALLOWED_EMAILS=

# ==================== Medula SGK Integration ====================
# Production SGK Medula web service credentials.
# Leave empty in dev — outbox worker logs requests instead of sending.
MEDULA_BASE_URL=https://medulatest.sgk.gov.tr
MEDULA_USERNAME=
MEDULA_PASSWORD=
MEDULA_FACILITY_CODE=
MEDULA_DOCTOR_CODE=
# Outbox worker tuning
MEDULA_OUTBOX_POLL_INTERVAL=5s
MEDULA_OUTBOX_MAX_RETRIES=5

# ==================== MERNIS (TC Kimlik No verification) ====================
# NVI KPSPublicV2 endpoint — used for TC kimlik no validation at patient admission.
MERNIS_ENDPOINT=https://tckimlik.nvi.gov.tr/Service/KPSPublicV2.asmx
# Cache TTL for successful verifications (TC data rarely changes).
MERNIS_CACHE_TTL=720h

# ==================== KVKK Compliance ====================
# Audit log retention (default 10 years for health data).
AUDIT_RETENTION_DAYS=3650
# Field-level encryption key (32-byte hex). Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=

# ==================== Analytics (optional) ====================
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
ANALYTICS_DISABLED=
